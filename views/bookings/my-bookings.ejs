<%- include('../partials/header') %>

<section class="bookings-section">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h1 style="font-size: 28px; font-weight: 800;">My Service Bookings</h1>
    <a href="/bookings/new" class="btn btn-primary btn-sm">Book New Service</a>
  </div>

  <% if (bookings.length === 0) { %>
    <div class="card" style="text-align: center; padding: 48px 24px;">
      <div style="font-size: 40px; margin-bottom: 16px;">❄</div>
      <h3 style="font-size: 20px; font-weight: 700; margin-bottom: 8px;">No Bookings Found</h3>
      <p style="color: var(--text-muted); margin-bottom: 20px; font-size: 14px;">You haven't scheduled any AC repair or service appointments yet.</p>
      <a href="/bookings/new" class="btn btn-primary">Schedule Your First Service</a>
    </div>
  <% } else { %>
    <div class="bookings-table-wrapper">
      <table class="bookings-table">
        <thead>
          <tr>
            <th>Booking ID</th>
            <th>Service Name</th>
            <th>Schedule Date & Time</th>
            <th>Status</th>
            <th>Assigned Technician</th>
            <th>Price Est.</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(booking => { %>
            <tr>
              <td style="font-weight: 800; color: var(--primary);" data-label="Booking ID"><%= booking.id %></td>
              <td style="font-weight: 700;" data-label="Service Name"><%= booking.serviceName %></td>
              <td style="font-weight: 600;" data-label="Schedule"><%= booking.bookingDate %> <br><span style="color: var(--text-muted); font-size: 12px; font-weight: 500;"><%= booking.bookingTimeSlot %></span></td>
              <td data-label="Status">
                <span class="status-badge <%= booking.status %>"><%= booking.status %></span>
              </td>
              <td style="font-weight: 600;" data-label="Technician">
                <% if (booking.technicianName) { %>
                  <span style="color: var(--secondary);">👨‍🔧 <%= booking.technicianName %></span>
                <% } else { %>
                  <span style="color: var(--text-muted); font-style: italic; font-weight: 500; font-size: 13px;">Awaiting Assignment</span>
                <% } %>
              </td>
              <td style="font-weight: 700; color: var(--primary);" data-label="Price Est."><%= booking.servicePrice %></td>
              <td data-label="Action">
                <a href="/bookings/confirmation?id=<%= booking.id %>" class="btn btn-secondary btn-sm" style="padding: 6px 12px; font-size: 12px;">Details</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
