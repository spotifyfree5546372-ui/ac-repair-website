<%- include('../partials/header') %>

<div class="confirmation-container">
  <div class="success-icon">✔</div>
  <h1 style="font-size: 32px; font-weight: 800; color: var(--text-main); margin-bottom: 8px;">Booking Confirmed!</h1>
  <p style="color: var(--text-muted); font-size: 15px;">
    Your booking was successful. A professional technician will arrive on your scheduled date and time.
  </p>

  <div class="booking-details-box card">
    <h3 style="font-size: 18px; font-weight: 800; margin-bottom: 20px; text-align: center; color: var(--success);">Booking Reference: <%= booking.id %></h3>
    
    <!-- Progress Tracker Timeline -->
    <div class="tracker-container">
      <% 
        let step1Class = "active";
        let step2Class = "";
        let step3Class = "";
        let connectorClass = "step-1";
        
        if (booking.status === 'pending') {
          step1Class = "active current";
        } else if (booking.status === 'assigned') {
          step1Class = "active";
          step2Class = "active current";
          connectorClass = "step-2";
        } else if (booking.status === 'completed') {
          step1Class = "active";
          step2Class = "active";
          step3Class = "active current";
          connectorClass = "step-3";
        }
      %>
      <div class="tracker-steps">
        <div class="tracker-connector-active <%= connectorClass %>"></div>
        
        <div class="step-node <%= step1Class %>">
          <div class="step-dot">1</div>
          <span class="step-label">Placed</span>
        </div>
        <div class="step-node <%= step2Class %>">
          <div class="step-dot">2</div>
          <span class="step-label">Assigned</span>
        </div>
        <div class="step-node <%= step3Class %>">
          <div class="step-dot">3</div>
          <span class="step-label">Done</span>
        </div>
      </div>
    </div>

    <div class="detail-row">
      <span class="detail-label">Service Type:</span>
      <span class="detail-value"><%= booking.serviceName %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Date & Time:</span>
      <span class="detail-value"><%= booking.bookingDate %> at <%= booking.bookingTimeSlot %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Contact Phone:</span>
      <span class="detail-value"><%= booking.contactPhone %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Service Address:</span>
      <span class="detail-value" style="text-align: right; max-width: 250px; word-wrap: break-word;"><%= booking.address %></span>
    </div>
    <div class="detail-row">
      <span class="detail-label">Booking Status:</span>
      <span class="status-badge <%= booking.status %>"><%= booking.status %></span>
    </div>
    
    <% if (booking.technicianName) { %>
      <div class="tech-profile-card">
        <div class="tech-avatar">👨‍🔧</div>
        <div class="tech-bio">
          <h4 style="margin: 0; font-size: 15px; font-weight: 800; color: var(--text-main);"><%= booking.technicianName %></h4>
          <p style="margin: 2px 0 0 0; font-size: 12.5px; font-weight: 700; color: var(--success);">⭐⭐⭐⭐⭐ 5.0 (Certified)</p>
          <p style="margin: 4px 0 0 0; font-size: 12px; color: var(--text-muted); line-height: 1.4;">Amaan AC Service Specialist assigned to your cooling unit.</p>
        </div>
        <div class="tech-actions">
          <a href="tel:+919719316515" class="tech-btn tech-btn-call">📞 Call Tech</a>
          <a href="https://wa.me/919719316515?text=Hello%20Amaan,%20I%20have%20an%20active%20AC%20service%20booking%20(Ref:%20<%= booking.id %>)." target="_blank" rel="noopener noreferrer" class="tech-btn tech-btn-wa">💬 WhatsApp</a>
        </div>
      </div>
    <% } %>
  </div>

  <!-- WhatsApp Booking Share Alert Card -->
  <div style="margin-top: 24px; padding: 24px; background-color: rgba(37, 211, 102, 0.04); border: 1px solid rgba(37, 211, 102, 0.15); border-radius: var(--radius-lg); text-align: center; max-width: 500px; margin-left: auto; margin-right: auto; box-shadow: var(--shadow-sm); transition: transform 0.3s ease;">
    <h4 style="margin: 0 0 8px 0; font-size: 16px; font-weight: 800; color: #128C7E; display: flex; align-items: center; justify-content: center; gap: 8px;">
      <svg style="width: 20px; height: 20px;" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Fast WhatsApp Confirmation
    </h4>
    <p style="margin: 0 0 18px 0; font-size: 13.5px; color: var(--text-muted); line-height: 1.5;">
      Send booking details directly to Amaan on WhatsApp to lock in your schedule immediately!
    </p>
    <% 
      let waText = encodeURIComponent(`Hello Amaan, I just booked an AC service! \n\n*Booking Details:*\n• *Reference:* ${booking.id}\n• *Service:* ${booking.serviceName}\n• *Date & Time:* ${booking.bookingDate} at ${booking.bookingTimeSlot}\n• *Address:* ${booking.address}\n• *Phone:* ${booking.contactPhone}`);
    %>
    <a href="https://wa.me/919719316515?text=<%= waText %>" target="_blank" rel="noopener noreferrer" class="btn" style="background-color: #25D366; color: white; border: none; font-weight: 700; width: 100%; max-width: 320px; display: inline-flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 4px 12px rgba(37, 211, 102, 0.25);">
      Send Details on WhatsApp
    </a>
  </div>

  <div style="margin-top: 30px; display: flex; justify-content: center; gap: 16px;">
    <a href="/bookings/my-bookings" class="btn btn-secondary">View My Bookings</a>
    <a href="/" class="btn btn-primary">Go to Homepage</a>
  </div>
</div>

<%- include('../partials/footer') %>
