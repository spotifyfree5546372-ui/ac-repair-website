<%- include('../partials/header') %>

<section style="padding: 40px 0;">
  <h1 style="font-size: 32px; font-weight: 800; margin-bottom: 24px;">Admin Operations Panel</h1>

  <!-- Stats Grid -->
  <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
    <div class="stat-card filter-card active" onclick="filterBookings('all', this)" style="cursor: pointer; transition: transform 0.2s;">
      <h3>Total Bookings</h3>
      <div class="value"><%= stats.total %></div>
    </div>
    <div class="stat-card filter-card" onclick="filterBookings('pending', this)" style="cursor: pointer; transition: transform 0.2s;">
      <h3>Pending</h3>
      <div class="value" style="color: var(--warning);"><%= stats.pending %></div>
    </div>
    <div class="stat-card filter-card" onclick="filterBookings('assigned', this)" style="cursor: pointer; transition: transform 0.2s;">
      <h3>Assigned</h3>
      <div class="value" style="color: var(--secondary);"><%= stats.assigned %></div>
    </div>
    <div class="stat-card filter-card" onclick="filterBookings('completed', this)" style="cursor: pointer; transition: transform 0.2s;">
      <h3>Completed</h3>
      <div class="value" style="color: var(--success);"><%= stats.completed %></div>
    </div>
    <div class="stat-card filter-card" onclick="filterBookings('rejected', this)" style="cursor: pointer; transition: transform 0.2s;">
      <h3>Rejected</h3>
      <div class="value" style="color: #F2181E;"><%= stats.rejected %></div>
    </div>
  </div>

  <h2 style="font-size: 20px; font-weight: 800; margin-bottom: 16px;">Customer Service Requests</h2>

  <% if (bookings.length === 0) { %>
    <div class="card" style="text-align: center; padding: 40px;">
      <p style="color: var(--text-muted); font-size: 15px;">No bookings registered in the system yet.</p>
    </div>
  <% } else { %>
    <div class="bookings-table-wrapper">
      <table class="bookings-table">
        <thead>
          <tr>
            <th>Booking ID</th>
            <th>Customer Details</th>
            <th>Service Details</th>
            <th>Schedule</th>
            <th>Status</th>
            <th>Assigned Tech / Actions</th>
          </tr>
        </thead>
        <tbody>
          <% bookings.forEach(booking => { %>
            <tr class="booking-row" data-status="<%= booking.status %>">
              <td style="font-weight: 800; color: var(--primary);" data-label="Booking ID"><%= booking.id %></td>
              <td data-label="Customer">
                <span style="font-weight: 700;"><%= booking.userName %></span><br>
                <span style="color: var(--text-muted); font-size: 12px; font-weight: 500;"><%= booking.userEmail %></span><br>
                <span style="color: var(--text-muted); font-size: 12px; font-weight: 500;"><%= booking.contactPhone %></span>
              </td>
              <td data-label="Service Details">
                <span style="font-weight: 700;"><%= booking.serviceName %></span><br>
                <span style="color: var(--text-muted); font-size: 12px; max-width: 200px; display: inline-block; word-wrap: break-word;"><%= booking.address %></span>
              </td>
              <td style="font-weight: 600;" data-label="Schedule">
                <%= booking.bookingDate %><br>
                <span style="color: var(--text-muted); font-size: 12px; font-weight: 500;"><%= booking.bookingTimeSlot %></span>
              </td>
              <td data-label="Status">
                <span class="status-badge <%= booking.status %>"><%= booking.status %></span>
              </td>
              <td data-label="Assign / Actions">
                <% if (booking.status === 'pending') { %>
                  <div style="display: flex; flex-direction: column; gap: 8px; align-items: flex-start;">
                    <form action="/admin/assign-technician" method="POST" class="assign-form">
                      <input type="hidden" name="bookingId" value="<%= booking.id %>">
                      <select name="technicianId" class="assign-select" required>
                        <option value="">Assign Tech</option>
                        <% technicians.forEach(tech => { %>
                          <option value="<%= tech.id %>"><%= tech.name %> (<%= tech.rating %>⭐)</option>
                        <% }) %>
                      </select>
                      <button type="submit" class="btn btn-primary btn-sm">Assign</button>
                    </form>
                    <form action="/admin/update-status" method="POST">
                      <input type="hidden" name="bookingId" value="<%= booking.id %>">
                      <input type="hidden" name="status" value="rejected">
                      <button type="submit" class="btn btn-secondary btn-sm" style="background-color: rgba(242, 24, 30, 0.05); color: #F2181E; border-color: rgba(242, 24, 30, 0.15); font-size: 11px; padding: 4px 10px; font-weight: 700;">Reject Booking</button>
                    </form>
                  </div>
                <% } else if (booking.status === 'assigned') { %>
                  <div style="display: flex; flex-direction: column; gap: 8px; align-items: flex-start;">
                    <span style="font-weight: 700; color: var(--secondary); font-size: 13px;">👨‍🔧 <%= booking.technicianName %></span>
                    <div style="display: flex; gap: 8px;">
                      <form action="/admin/update-status" method="POST">
                        <input type="hidden" name="bookingId" value="<%= booking.id %>">
                        <input type="hidden" name="status" value="completed">
                        <button type="submit" class="btn btn-secondary btn-sm" style="background-color: var(--success-light); color: var(--success); border-color: rgba(16, 185, 129, 0.15); font-size: 11px; padding: 4px 10px; font-weight: 700;">Mark Completed</button>
                      </form>
                      <form action="/admin/update-status" method="POST">
                        <input type="hidden" name="bookingId" value="<%= booking.id %>">
                        <input type="hidden" name="status" value="rejected">
                        <button type="submit" class="btn btn-secondary btn-sm" style="background-color: rgba(242, 24, 30, 0.05); color: #F2181E; border-color: rgba(242, 24, 30, 0.15); font-size: 11px; padding: 4px 10px; font-weight: 700;">Reject</button>
                      </form>
                    </div>
                  </div>
                <% } else if (booking.status === 'rejected') { %>
                  <span style="color: #F2181E; font-weight: 700; font-size: 13px;">❌ Booking Rejected</span>
                <% } else { %>
                  <span style="color: var(--success); font-weight: 700; font-size: 13px;">👨‍🔧 <%= booking.technicianName || 'N/A' %> (Completed)</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<script>
  function filterBookings(status, clickedElement) {
    // 1. Visual update for active card
    document.querySelectorAll('.filter-card').forEach(card => {
      card.style.transform = 'scale(1)';
      card.style.boxShadow = 'var(--shadow-sm)';
      card.style.border = 'none';
    });
    
    clickedElement.style.transform = 'scale(1.05)';
    clickedElement.style.boxShadow = 'var(--shadow-lg)';
    clickedElement.style.border = '2px solid var(--primary)';

    // 2. Filter the table rows
    const rows = document.querySelectorAll('.booking-row');
    rows.forEach(row => {
      if (status === 'all') {
        row.style.display = '';
      } else {
        if (row.getAttribute('data-status') === status) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      }
    });
  }

  // Initialize all cards with default shadow
  document.querySelectorAll('.filter-card').forEach(card => {
    card.style.boxShadow = 'var(--shadow-sm)';
  });
  
  // Set initial active state for 'Total'
  const firstCard = document.querySelector('.filter-card');
  if(firstCard) {
    firstCard.style.border = '2px solid var(--primary)';
  }
</script>

<%- include('../partials/footer') %>
