<%- include('partials/header') %>

<div class="auth-container" style="max-width: 500px; text-align: center; margin: 80px auto;">
  <div style="font-size: 60px; margin-bottom: 20px;">⚠️</div>
  <h1 style="font-size: 28px; font-weight: 800; margin-bottom: 15px;"><%= title %></h1>
  
  <div class="clay-card peach" style="margin-bottom: 30px; text-align: center;">
    <p style="font-size: 16px; font-weight: 600; color: var(--danger-text);"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>
  </div>

  <a href="/" class="btn btn-primary">Return to Home</a>
</div>

<%- include('partials/footer') %>
