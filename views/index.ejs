  <div class="section-header reveal-on-scroll" style="text-align: center; margin-bottom: 48px;">
    <span style="font-size: 13px; font-weight: 800; color: var(--primary); text-transform: uppercase; letter-spacing: 1.5px;">Our Service Focus</span>
    <h2 style="margin-top: 8px;">EVERYTHING YOU NEED FOR YOUR AC</h2>
  </div>

  <div class="numbered-grid">
    <div class="numbered-card reveal-on-scroll">
      <div class="numbered-num">.01</div>
      <h3 class="numbered-title">Installation</h3>
      <p class="numbered-desc">Professional setup and alignment for split and window AC units with certified mounting, piping, and performance leak testing.</p>
    </div>
    <div class="numbered-card reveal-on-scroll">
      <div class="numbered-num">.02</div>
      <h3 class="numbered-title">Jet Cleaning</h3>
      <p class="numbered-desc">Deep pressure-pump wash for filters, cooling coils, drain trays, and condensers to maximize cooling speeds and restore airflow.</p>
    </div>
    <div class="numbered-card reveal-on-scroll">
      <div class="numbered-num">.03</div>
      <h3 class="numbered-title">Repairs & Gas</h3>
      <p class="numbered-desc">Refrigerant gas top-ups with pressure dial checking, copper pipe brazing, and complete HVAC diagnostic troubleshooting.</p>
    </div>
  </div>
</section>

