</main>

<!-- Hero PlumFix Section -->
<section class="hero-plumfix">
  <!-- Giant Watermark Text -->
  <div class="hero-watermark">AMAAN</div>
  
  <div class="hero-plumfix-container">
    <!-- Left Column Content -->
    <div class="hero-left-content reveal-on-scroll">
      <div class="hero-pill-badge">
        <span class="pill-dot"></span> Reliable AC Services
      </div>
      
      <h1 class="hero-title-plumfix">
        COMPLETE HOME<br>
        <span>COOLING</span> SOLUTIONS
      </h1>
      
      <p>We deliver certified AC repair, jet cleaning, and diagnostics to keep your space fresh and your systems running efficiently.</p>
      
      <div class="hero-action-buttons">
        <a href="/bookings/new" class="btn-plumfix-primary">Book Service &rarr;</a>
        <a href="/services" class="btn-plumfix-secondary">Learn More &rarr;</a>
      </div>
    </div>
    
    <!-- Right Column Image & Stats overlay -->
