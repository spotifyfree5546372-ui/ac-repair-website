            <span class="avatar-circle" style="background-color: #f44b0d; color: white; font-weight:700;">A</span>
            <span class="avatar-circle" style="background-color: #3b82f6; color: white; font-weight:700;">S</span>
            <span class="avatar-circle" style="background-color: #10b981; color: white; font-weight:700;">M</span>
          </div>
