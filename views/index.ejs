<%- include('partials/header') %>

<section class="hero-section">
  <div class="hero-left">
    <h1 id="hero-title">Instant AC Repair & <br><span>HVAC Service</span></h1>
    <p>Get fast, certified cooling services directly to your doorstep. Select a service, schedule your convenient slot, and track our professional technicians in real-time.</p>
    
    <div class="trust-badge-row" style="margin-bottom: 24px;">
      <span class="trust-badge-item">🏆 10+ Years Exp</span>
      <span class="trust-badge-item">🛡 Certified HVAC Techs</span>
      <span class="trust-badge-item">⚡ 100% Genuine Parts</span>
    </div>
    
    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-num">99.4%</span>
        <span class="stat-label">Customer Satisfaction</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">15k+</span>
        <span class="stat-label">Repairs Completed</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">24/7</span>
        <span class="stat-label">Emergency Support</span>
      </div>
    </div>
  </div>

  <div class="hero-right">
    <div class="hero-right-card">
      <h3 style="font-size: 18px; font-weight: 800; margin-bottom: 15px; color: var(--text-main);">Quick Booking Widget</h3>
      <form action="/bookings/new" method="GET">
        <div class="form-group" style="margin-bottom: 15px;">
          <label for="serviceSelect" class="form-label" style="font-size: 13px;">Select Needed Service</label>
          <select name="service" id="serviceSelect" class="form-control" style="padding: 10px 14px;" required>
            <option value="">Select a Service</option>
            <% services.forEach(service => { %>
              <option value="<%= service.id %>"><%= service.name %></option>
            <% }) %>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px;" id="hero-quick-book">Continue Booking &rarr;</button>
      </form>
    </div>
  </div>
</section>

<section style="padding: 40px 0;">
  <div class="section-header">
    <h2 class="section-title">Our Repair & Maintenance Services</h2>
    <p class="section-subtitle">Certified technicians, transparent diagnostic estimates, and high-performance cooling results.</p>
  </div>

  <div class="services-grid">
    <% services.forEach((service, index) => { %>
      <div class="card service-card">
        <div class="service-icon">
          <% if (service.id.includes('install') && !service.id.includes('uninstall')) { %>
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="9" rx="1.5"></rect>
              <line x1="2" y1="9" x2="22" y2="9"></line>
              <path d="M6 17v2M12 17v2M18 17v2"></path>
              <path d="M19 13v4m-2-2h4"></path>
            </svg>
          <% } else if (service.id.includes('uninstall')) { %>
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="9" rx="1.5"></rect>
              <line x1="2" y1="9" x2="22" y2="9"></line>
              <path d="M12 14v5m-3-2 3-3 3 3"></path>
              <path d="M17 15h4"></path>
            </svg>
          <% } else if (service.id.includes('jet-service')) { %>
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
              <path d="M3 12h3M18 12h3M12 18v3"></path>
            </svg>
          <% } else if (service.id.includes('gas')) { %>
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="7" y="7" width="10" height="13" rx="2"></rect>
              <path d="M10 7V4h4v3"></path>
              <circle cx="12" cy="13" r="3"></circle>
              <path d="m12 13 1.5-1.5"></path>
            </svg>
          <% } else { %>
            <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
            </svg>
          <% } %>
        </div>
        <span class="category-badge <%= service.category.toLowerCase() %>"><%= service.category %></span>
        <h3 class="service-name"><%= service.name %></h3>
        <p class="service-desc"><%= service.description %></p>
        <div class="service-meta">
          <span class="service-price">Estimate: <%= service.price %></span>
          <span class="service-duration">⏱ <%= service.duration %></span>
        </div>
        <div style="margin-top: 20px;">
          <a href="/bookings/new?service=<%= service.id %>" class="btn btn-secondary btn-sm" style="width: 100%; text-align: center;" id="book-<%= service.id %>">Book Now</a>
        </div>
      </div>
    <% }) %>
  </div>
</section>

<!-- Live Google Reviews Section -->
<section class="reviews-section container">
  <div class="google-rating-card">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" style="display:inline-block; vertical-align:middle;">
      <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
      <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
      <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22c-.87-2.6-2.86-4.53-6.16-4.53z" fill="#FBBC05"/>
      <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
    </svg>
    <div class="google-rating-info">
      <h4 style="margin:0; font-size:18px; font-weight:800;">Aman AC Service</h4>
