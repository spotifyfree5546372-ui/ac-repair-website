<main class="container">

<!-- Showcase Services Section -->
<section class="showcase-section">
  <div class="section-header reveal-on-scroll" style="text-align: center; margin-bottom: 48px;">
    <h2>OUR SERVICES</h2>
    <p style="font-size: 15px; color: var(--text-muted);">Certified technicians, transparent diagnostic estimates, and high-performance cooling results.</p>
  </div>

  <div class="showcase-grid">
    <% services.forEach(service => { %>
      <a href="/bookings/new?service=<%= service.id %>" class="showcase-card reveal-on-scroll" id="showcase-<%= service.id %>">
        <div class="showcase-content">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 4px;">
            <div class="service-icon" style="background-color: var(--primary-light); color: var(--primary); width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
              <% if (service.id.includes('install') && !service.id.includes('uninstall')) { %>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="9" rx="1.5"></rect>
                  <line x1="2" y1="9" x2="22" y2="9"></line>
                  <path d="M6 17v2M12 17v2M18 17v2"></path>
                  <path d="M19 13v4m-2-2h4"></path>
                </svg>
              <% } else if (service.id.includes('uninstall')) { %>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="9" rx="1.5"></rect>
                  <line x1="2" y1="9" x2="22" y2="9"></line>
                  <path d="M12 14v5m-3-2 3-3 3 3"></path>
                  <path d="M17 15h4"></path>
                </svg>
              <% } else if (service.id.includes('jet-service')) { %>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
                  <path d="M3 12h3M18 12h3M12 18v3"></path>
                </svg>
              <% } else if (service.id.includes('gas')) { %>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="7" y="7" width="10" height="13" rx="2"></rect>
                  <path d="M10 7V4h4v3"></path>
                  <circle cx="12" cy="13" r="3"></circle>
                  <path d="m12 13 1.5-1.5"></path>
                </svg>
              <% } else { %>
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>
                </svg>
              <% } %>
            </div>
            <span class="category-badge <%= service.category.toLowerCase() %>" style="margin-bottom: 0;"><%= service.category %></span>
          </div>

          <div class="showcase-text">
            <h3 class="showcase-title"><%= service.name %></h3>
            <p class="showcase-desc"><%= service.description %></p>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 6px;">
              <span class="showcase-price">Estimate: <%= service.price %></span>
              <span style="font-size: 13px; color: var(--text-muted); font-weight: 500;">⏱ <%= service.duration %></span>
            </div>
          </div>
          
          <div class="showcase-action">
            Book Now &rarr;
          </div>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<!-- Numbered Categories -->
