      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // FAQ Accordion
    const faqItems = document.querySelectorAll('.faq-item');
    faqItems.forEach(item => {
      item.addEventListener('click', () => {
        const isActive = item.classList.contains('active');
        faqItems.forEach(other => other.classList.remove('active'));
        if (!isActive) {
          item.classList.add('active');
        }
      });
    });

    // Scroll Reveal Animation (Intersection Observer)
    const animElements = document.querySelectorAll('.reveal-on-scroll');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const target = entry.target;
          
          // Stagger items if they belong to a grid/flex container
          const parent = target.parentElement;
          if (parent && (
            parent.classList.contains('showcase-grid') || 
            parent.classList.contains('numbered-grid') || 
            parent.classList.contains('reviews-grid') || 
            parent.classList.contains('stats-bar')
          )) {
            const siblings = Array.from(parent.children).filter(el => el.classList.contains('reveal-on-scroll'));
            const index = siblings.indexOf(target);
            if (index !== -1) {
              target.style.transitionDelay = `${index * 80}ms`;
            }
          }
          
          target.classList.add('visible');
          observer.unobserve(target);
        }
      });
    }, {
      threshold: 0.05,
      rootMargin: '0px 0px -40px 0px'
    });

    animElements.forEach(el => observer.observe(el));
  });
</script>

