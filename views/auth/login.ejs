<%- include('../partials/header') %>

<div class="auth-container">
  <div class="auth-header">
    <h2>Welcome Back</h2>
    <p>Sign in to your CoolFix account to manage bookings.</p>
  </div>

  <% if (error) { %>
    <div class="error-alert">
      <%= error %>
    </div>
  <% } %>

  <div class="card">
    <form action="/auth/login" method="POST" id="login-form">
      <div class="form-group">
        <label for="email" class="form-label">Email Address</label>
        <input type="email" name="email" id="email" class="form-control" placeholder="yourname@example.com" required>
      </div>

      <div class="form-group">
        <label for="password" class="form-label">Password</label>
        <input type="password" name="password" id="password" class="form-control" placeholder="••••••••" required>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 10px;" id="login-submit">Login</button>
    </form>
  </div>

  <!-- Demo credentials display -->
  <div class="card" style="margin-top: 20px; padding: 20px; box-shadow: var(--shadow-sm); background-color: var(--primary-light); border-color: rgba(37, 99, 235, 0.12);">
    <h4 style="font-weight: 700; margin-bottom: 8px; color: var(--primary); font-size: 14px;">Demo Test Accounts:</h4>
    <p style="font-size: 13px; margin-bottom: 4px;">
      <strong>User:</strong> john@example.com / password123
    </p>
    <p style="font-size: 13px; margin-bottom: 0;">
      <strong>Admin:</strong> admin@acservice.com / adminpassword
    </p>
  </div>

  <div class="auth-footer">
    Don't have an account? <a href="/auth/signup" id="go-to-signup">Sign Up Here</a>
  </div>
</div>

<%- include('../partials/footer') %>
